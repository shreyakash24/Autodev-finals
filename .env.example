# Environment Configuration
# Copy this file to .env and fill in your values

# LLM Provider Configuration
# Choose your LLM provider: 'openai' or 'groq'
LLM_PROVIDER=openai

# OpenAI API Key (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here

# Groq API Key (required if LLM_PROVIDER=groq)
GROQ_API_KEY=your_groq_api_key_here

# LLM Model Configuration
# For OpenAI: gpt-4, gpt-4-turbo, gpt-3.5-turbo
# For Groq: llama3-70b-8192, mixtral-8x7b-32768, gemma-7b-it
LLM_MODEL=gpt-4

# Azure DevOps Configuration (optional)
ADO_ORG_URL=https://dev.azure.com/your-organization
ADO_PAT=your_personal_access_token
ADO_PROJECT=your_project_name

# Server Configuration
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=true

# Agent Configuration
MAX_PARALLEL_TASKS=4
TEST_COVERAGE_THRESHOLD=80
